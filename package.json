{
  "name": "mestria",
  "version": "1.0.0",
  "description": "Uma plataforma web de RPG de mesa potencializada por Inteligência Artificial. A aplicação permite a criação de campanhas multiplayer em tempo real. O grande diferencial é a integração com LLMs, onde a IA atua como o Dungeon Master (Mestre), gerando narrativas dinâmicas, controlando NPCs, validando regras e respondendo às ações dos jogadores.",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gustavonunespaz/MestrIA.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gustavonunespaz/MestrIA/issues"
  },
  "homepage": "https://github.com/gustavonunespaz/MestrIA#readme",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "prisma": "^5.7.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
